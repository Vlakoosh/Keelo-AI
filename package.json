{
  "name": "keelo-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "npm run tailwind:build && expo start",
    "start:tunnel": "npm run tailwind:build && expo start --clear --tunnel",
    "dev": "npm run tailwind:build && expo start --clear",
    "android": "npm run tailwind:build && expo start --android",
    "ios": "npm run tailwind:build && expo start --ios",
    "web": "npm run tailwind:build && expo start --web",
    "tailwind:build": "tailwindcss -i ./src/styles/global.css -o ./.nativewind/tailwind.css",
    "tailwind:watch": "tailwindcss -i ./src/styles/global.css -o ./.nativewind/tailwind.css --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  },
  "private": true
}
